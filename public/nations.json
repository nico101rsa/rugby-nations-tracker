  "digests": {
    "28": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Transfer news",
          "heading": "Joji Nasova remains with Fijian Drua as Newcastle Red Bulls move collapses",
          "body": "Joji Nasova will remain with the Fijian Drua after his planned move to Premiership side Newcastle Red Bulls was cancelled for \"personal reasons\". The 25-year-old wing, a silver medallist with the sevens side at the Paris Olympics, has been released from his contract before moving to England. Red Bulls general manager Neil McIlroy stated the club respects the \"unique personal circumstances\" behind the decision. It is a significant boost for the Drua to retain Nasova, who has scored four tries in three appearances for Fiji."
        }
      ],
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "386": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Player welfare",
          "heading": "Ben Earl and England squad question brutal Nations Championship travel demands",
          "body": "England’s players have raised concerns regarding the sustainability of the current Nations Championship format after covering 26,000 miles across three continents this month. No. 8 Ben Earl, who started all three fixtures, labelled the schedule “brutal” and suggested that centralising tournament venues would better serve both the players and supporters. The squad’s feedback highlights the logistical strain of a demanding season, with players openly questioning the necessity of such extensive travel as the tournament moves towards its conclusion."
        }
      ],
      "source": {
        "name": "Guardian Rugby Union"
      }
    },
    "387": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Tournament standing",
          "heading": "France remain in contention as the Nations Championship race intensifies",
          "body": "Les Bleus sit third in the current Nations Championship log with 12 points, keeping them firmly in the hunt following their recent victory over Japan. With South Africa leading the southern hemisphere and France positioned strongly in the north, the possibility of a marquee final at Twickenham remains a talking point for supporters. Having secured two wins from 3 outings, the squad is well-placed to challenge for a top-two finish as the competition moves towards the November fixtures."
        }
      ],
      "source": {
        "name": "SA Rugby Magazine"
      }
    },
    "388": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Coaching scrutiny",
          "heading": "Andy Farrell rues Ireland’s error-strewn display against clinical All Blacks",
          "body": "Andy Farrell has demanded improvements after Ireland concluded their campaign with a 40-21 defeat to New Zealand. Describing the performance as “inaccurate,” the head coach highlighted discipline issues and handling errors as the primary causes of a punishing first half at Eden Park. While tries from Jack Conan, Joe McCarthy, and Hugo Keenan showed fight, the loss leaves Ireland winless in their last four encounters with the All Blacks, prompting an immediate end-of-season reassessment of the squad’s tactical development."
        }
      ],
      "source": {
        "name": "Guardian Rugby Union"
      }
    },
    "389": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Disciplinary blow",
          "heading": "World Rugby bans Gonzalo Quesada for two matches following referee comments",
          "body": "Italy head coach Gonzalo Quesada will serve a two-match ban following his suspension by World Rugby. The disciplinary action stems from remarks made about match official Luc Ramos during the Azzurri’s recent Nations Championship defeat to the All Blacks. Quesada had labelled the referee’s performance as “super poor” in the aftermath of that fixture. This sidelining comes as the team looks to address a challenging start to the tournament, having lost all 3 of their opening matches."
        }
      ]
    },
    "390": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Tournament progress",
          "heading": "Scotland show improvement as summer campaign concludes with positive momentum",
          "body": "Following the bonus-point victory over Fiji, Scotland finish their summer tests having secured two wins from three matches. Despite a sluggish opening half at Murrayfield, the impact of the bench—including tries from Pierre Schoeman, Scott Cummings, and Jamie Dobie—underscored a growing depth in Gregor Townsend’s squad. While challenges remain in matching the consistency of the world's elite, the team closes this block of the Nations Championship with 16 tries scored and a positive trajectory toward the autumn tests."
        }
      ],
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "391": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Selection call",
          "heading": "Jac Morgan insists Wales are closing the gap to world's best",
          "body": "Following the 43-0 defeat in Durban, flanker Jac Morgan has maintained that Wales are making progress despite a difficult Nations Championship campaign. While Steve Tandy’s side has struggled for results, losing comprehensively to South Africa and Argentina after an opening win over Fiji, Morgan insists the group is developing. \"I think we are – or at least we hope we are,\" said the Gloucester-bound forward. \"You can see the progress we've made since the autumn.\""
        }
      ],
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "460": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Coaching scrutiny",
          "heading": "Felipe Contepomi accuses England of 'lack of respect' after defeat",
          "body": "Felipe Contepomi walked out of his post-match media engagement following Saturday’s 31-24 loss to England. The head coach took issue with the conduct of the visitors in the changing room, claiming their loud celebrations displayed a \"lack of respect.\" This friction followed a chaotic fixture in which Argentina’s late comeback attempt was thwarted by the TMO, compounding a frustrating week for the Pumas. Contepomi had previously intervened to ask for the noise levels from the neighbouring dressing room to be reduced."
        }
      ],
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "461": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Transfer news",
          "heading": "Izaia Perese returns to Australia and signs with Queensland Reds",
          "body": "Wallabies centre Izaia Perese has committed his future to Australian rugby, signing a two-year deal with the Queensland Reds following his exit from Leicester Tigers. The move, which keeps him in the country through to 2028, is explicitly aimed at securing a spot in the squad for the 2027 Rugby World Cup. RA’s director of high performance, Peter Horne, stated the signing “reflects our focus on strengthening our depth and ensuring our best athletes are playing their rugby here in Australia.”"
        }
      ]
    },
    "463": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Tournament honours",
          "heading": "Japanese player earns selection in Nations Championship Team of the Month",
          "body": "Following the conclusion of the southern leg of the Nations Championship, Planet Rugby has named a Japanese player in their Team of the Month. The recognition reflects a breakthrough period for the squad, which saw the Brave Blossoms claim their first win in a tier-one competition earlier this month. While New Zealand and South Africa dominated the selection, the inclusion highlights the individual impact of the Japanese side during a challenging three-round series against Europe’s best."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "465": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Selection call",
          "heading": "Dave Rennie vindicated as Tupou Vaa’i shines in experimental loose forward role",
          "body": "Dave Rennie’s decision to deploy Tupou Vaa’i at blindside flanker has drawn praise following New Zealand's 40-21 victory over Ireland. While the move initially faced scrutiny, analysts have lauded the Chiefs forward’s impact in a pack that dominated the collision zone. With Patrick Tuipulotu also making a successful return from injury, Rennie now faces positive selection dilemmas. Jeff Wilson noted the tactical shift adds necessary physicality, stating: “He is a big body who we are going to need in South Africa.”"
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "467": {
      "date": "2026-07-21",
      "edition": "Tuesday 21 July",
      "sections": [
        {
          "kicker": "Selection strategy",
          "heading": "Rassie Erasmus flexes depth as Springboks sweep opening championship rounds",
          "body": "South Africa concludes the Southern Hemisphere leg of the Nations Championship sitting at the top of the log with three bonus-point victories. Rassie Erasmus has successfully navigated a challenging window by rotating heavily, blooding rookies while maintaining an unbeaten record of 130 points scored. After experimental lineups against Scotland and Wales, the head coach acknowledged that while his squad is operating with “unbelievable luxury,” there remains room to refine execution as the team turns its focus toward the upcoming series against New Zealand."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    }
  }
}