  "digests": {
    "28": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "MIDFIELD SWITCH",
          "heading": "Vakatawa Debuts for Fiji in Third Straight Defeat",
          "body": "Former France centre Virimi Vakatawa completed his international switch on Saturday, debuting in midfield during Fiji's 17-33 loss to Scotland in Edinburgh. The former Les Bleus star, who won 32 caps for France, provided a rare bright spot in the third-round defeat. The result leaves the Flying Fijians bottom of the log with three straight defeats. Head coach Senirusi Seruvakula now faces a lengthy break to find consistency and refine set pieces before his side returns to action against France."
        }
      ]
    },
    "386": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "Coaching scrutiny",
          "heading": "Borthwick Faces RFU Review Despite Argentina Triumph",
          "body": "Steve Borthwick's coaching future is under the spotlight as the RFU begins its scheduled review following Saturday's 31-24 victory over Argentina in Santiago del Estero. Despite securing the win, questions remain over England's identity following a Six Nations campaign that yielded just one victory. While the RFU previously offered support to the head coach through to next year's World Cup in Australia, there is no cast-iron guarantee as the board assesses the squad's progress."
        }
      ]
    },
    "387": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "OLYMPIC LEGACY",
          "heading": "Dupont’s Saint-Denis masterclass fuels confidence for Fiji clash",
          "body": "Antoine Dupont’s legacy continues to shadow the upcoming November test against Fiji, as memories of his seven-minute masterclass in Saint-Denis resurface. France’s 28-7 gold medal victory ended Fiji’s historic dominance on the Olympic stage and remains the psychological benchmark for this fixture. Former coach Jacques Brunel once described a 21-14 loss to the visitors as \"incomprehensible,\" but the current squad is far removed from the \"little boys\" of 2018, having proved they can dismantle Fijian systems under intense pressure."
        }
      ]
    },
    "388": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "Touring toll",
          "heading": "Depleted Ireland fall short of Eden Park history against All Blacks",
          "body": "Ireland’s pursuit of a historic victory at Eden Park ended in a 21-40 defeat, leaving the squad sixth in the Nations Championship log. Andy Farrell’s side arrived for the New Zealand leg of the tour significantly depleted, a factor that told as the All Blacks exerted control in the final quarter. Despite the setback, the touring party remains at two wins from three matches. The squad now enters a recovery phase following the physical encounter, with the coaching staff focusing on player management before the tournament continues."
        }
      ]
    },
    "389": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "DEFENSIVE CRISIS",
          "heading": "Italy sinks to 11th after heavy 10-57 defeat to Australia",
          "body": "Italy faces a difficult period of reflection following Saturday's 10-57 defeat to Australia, a result that leaves the Azzurri sitting 11th in the standings. After three consecutive losses to open the campaign, the side must address a defense that surrendered over 50 points. The result continues a trend of struggles against southern hemisphere opposition, including last year’s 45-0 loss in Gqeberha. The squad now enters a lengthy break, with months to recalibrate before facing South Africa in November."
        }
      ]
    },
    "390": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "NATIONS CHAMPIONSHIP",
          "heading": "Savea to captain New Zealand as Scots sit fifth",
          "body": "Scotland occupy fifth place in the inaugural Nations Championship standings following their 33-17 win against Fiji. Attention turns to the upcoming test against New Zealand, who have appointed Ardie Savea as captain under coach Dave Rennie. The senior squad may look to the set-piece success of the Under 20s, who recently utilized a dominant scrum and three driving maul tries to unsettle their Kiwi counterparts. Fergus Pringle’s side salvaged a bonus point in that 36-26 defeat, showing a blueprint for challenging the southern hemisphere power."
        }
      ]
    },
    "391": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "SCORING DROUGHT",
          "heading": "Springboks shutout leaves Wales reeling in Durban",
          "body": "Steve Tandy’s side faces a difficult post-match inquest after Saturday’s 43-0 defeat to South Africa. The world champions dominated the set piece and crossed for seven tries in Durban, condemning Wales to a second consecutive scoreless performance against the Springboks. With one win from three Nations Championship matches, the squad now enters a necessary recovery period before the autumn schedule. Training will likely focus on set-piece stability after the Welsh pack was demolished in the scrum during the opening exchanges of the Durban encounter."
        }
      ],
      "match": {
        "venue": "Durban"
      }
    },
    "460": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "RESPECT ROW",
          "heading": "Contepomi slams England for \"lack of respect\" after narrow defeat",
          "body": "Argentina sits eighth in the standings following the 24-31 loss to England, a result that saw Borthwick’s side repeat their 2025 success on Argentine soil. Head coach Felipe Contepomi has added heat to the rivalry, accusing the visitors of a \"lack of respect\" as his squad struggles for consistency. Despite a physical performance in the match officiated by Angus Gardner, Los Pumas have secured just one win in three fixtures and now face a four-month gap before their Round four encounter with Ireland."
        }
      ]
    },
    "461": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "CLINICAL REBOUND",
          "heading": "Wallabies ignite Nations Championship bid with dominant rout of Italy",
          "body": "Australia ignited their Nations Championship campaign on Saturday, crushing Italy 57-10 to secure their first win of the tournament. After consecutive losses to open the season, the Wallabies moved into seventh place on the log with a performance that silenced critics following a difficult opening fortnight. The clinical display significantly improved a point differential that now stands at +29, providing much-needed momentum for the squad. The side finally found the attacking cohesion that was absent during the first two rounds to comfortably overwhelm the Italian defense."
        }
      ]
    },
    "463": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "NATIONS CHAMPIONSHIP",
          "heading": "France outclass ragged Japan as southern series ends in Tokyo",
          "body": "Japan concluded their home Nations Championship series with a 15-42 loss to France in Tokyo, as Les Bleus crossed six times to exploit a \"ragged\" defense. While Kippei Ishida finished a silky counter-attack and Takuro Matsunaga added a penalty, the Brave Blossoms were unable to sustain their early mettle against the French set-piece. The result leaves Japan 10th in the standings with one win from three matches, highlighting the defensive gaps Eddie Jones must address before the tour resumes in November."
        }
      ]
    },
    "465": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "NATIONS CHAMPIONSHIP",
          "heading": "All Blacks move to 3-0 after clinical win over Ireland",
          "body": "New Zealand move to a 3-0 record in the inaugural Nations Championship following Saturday’s 40-21 victory over Ireland. The result keeps the All Blacks second in the standings after a clinical opening block that included a narrow win over France. While the senior side showcased efficiency, player development remains in focus at the Junior World Championship in Georgia; the Under 20s secured a 36-26 win over Scotland, despite the \"Baby Blacks\" front row conceding multiple penalties under heavy scrum pressure."
        }
      ]
    },
    "467": {
      "date": "2026-07-20",
      "edition": "Monday 20 July",
      "sections": [
        {
          "kicker": "LOG LEADERS",
          "heading": "Dominant Boks take control of Nations Championship table",
          "body": "South Africa sits clear at the summit of the inaugural Nations Championship table following a clinical 43-0 dismantling of Wales. The three-match sweep through the opening rounds leaves the world champions as the only unbeaten side in the 12-team log, supported by a defensive line that has conceded just 49 points. While the squad now enters a scheduled break before resuming the competition in Italy, the efficiency of the Round Three shutout in Cardiff establishes a formidable platform for the second half of the tournament."
        }
      ]
    }
  }
