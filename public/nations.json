  "digests": {
    "28": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "Transfer update",
          "heading": "Joji Nasova stays with Fijian Drua as Newcastle Red Bulls contract collapses",
          "body": "Fijian wing Joji Nasova will remain with the Fijian Drua next season after being released from his contract with Newcastle Red Bulls. The Premiership club agreed to cancel the deal for the 25-year-old Olympic silver medallist, citing personal reasons. Newcastle general manager Neil McIlroy stated they \"fully understand and respect the unique personal circumstances that have led to this decision.\" Nasova, who has scored four tries in three appearances for Fiji, provides a massive boost to the Drua."
        }
      ],
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "386": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "Discipline concerns",
          "heading": "Steve Borthwick relieves immediate pressure despite England's mounting crisis over discipline",
          "body": "Steve Borthwick has successfully cooled questions over his job security after leading England to a third-place standing in the Nations Championship's Northern Hemisphere table. Following a dismal run of five consecutive defeats, back-to-back victories over Fiji and Argentina have shifted the narrative. However, a chaotic finale in Santiago—which saw four England players carded—has sparked warnings that Borthwick's side are battling a discipline epidemic. The head coach must address these costly errors before hosting Australia in November."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "387": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "Squad depth",
          "heading": "Fabien Galthié's understudies prove France's immense squad depth on southern tour",
          "body": "Following the conclusion of the Southern Hemisphere leg of the Nations Championship, the focus turns to the staggering resources at Fabien Galthié's disposal. Despite resting key figures including Antoine Dupont, Charles Ollivon, and the injured Grégory Alldritt, a fresh-faced French touring squad still secured two victories from three matches. Galthié utilised 35 players across the tour, showcasing a formidable second string that pushed New Zealand close in Christchurch before defeating Australia and Japan. It leaves Les Bleus in a strong position ahead of November's clash with Fiji."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "388": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "Fly-half debate",
          "heading": "Brian O'Driscoll backs Jack Crowley as Ireland playmaker after Sam Prendergast's errors",
          "body": "Former Ireland captain Brian O'Driscoll has insisted Jack Crowley's position as the nation's premier playmaker remains secure despite Sam Prendergast's recent audition. With Crowley sidelined since mid-April by an obscure leg injury, Prendergast stepped in for the mid-year Tests but endured a mixed bag during Saturday's 40-21 defeat to New Zealand. Prendergast missed six of 22 tackle attempts in Auckland and was heavily targeted by the All Blacks. O'Driscoll noted the defensive contrast between the two is \"night and day\", suggesting Prendergast will continue to be a target for physical opponents."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "389": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "Form slump",
          "heading": "Italy suffer fourth consecutive defeat after heavy loss away to Australia",
          "body": "Italy's current run of form shows four straight defeats following their away loss to Australia in the Nations Championship group stage. In their last five fixtures, they have won just once and lost four times, with that sole victory now followed by a mounting losing streak. The latest setback came in a 57-10 defeat in Australia."
        }
      ],
      "rung": "data"
    },
    "390": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "Elite ambitions",
          "heading": "Pierre Schoeman insists Scotland belong among the world's top five",
          "body": "Following the hard-fought 33-17 victory over Fiji last weekend, prop Pierre Schoeman has rejected the idea that Scotland are merely closing the gap on rugby's elite. Echoing praise from South Africa coach Rassie Erasmus, the loosehead asserted: 'I feel we are a top-three, top-five team in the world.' Despite finishing the southern tour with two wins from three, Gregor Townsend's side still crave a defining statement victory. They head into the autumn international break sitting second in the northern standings behind France."
        }
      ],
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "391": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "COACHING ROLE",
          "heading": "Leigh Halfpenny signs full-time Cardiff coaching deal after Wales backroom stint",
          "body": "Wales legend Leigh Halfpenny has transitioned to a full-time coaching role, joining Cardiff as their new kicking and academy skills coach. The 37-year-old, who retired last season with 101 Test caps and 801 points for his country, spent the opening three rounds of the Nations Championship working with the national squad. Halfpenny believes that experience will aid his transition, stating, 'I am thrilled to join Cardiff on a full-time basis.' Cardiff head coach Corniel van Zyl praised his meticulous approach."
        }
      ],
      "source": {
        "name": "SA Rugby Magazine"
      }
    },
    "460": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "Misconduct charge",
          "heading": "Tomás Albornoz faces World Rugby hearing following referee confrontation in England defeat",
          "body": "Fly-half Tomás Albornoz has become the first player charged under World Rugby’s new Match Official Abuse Sanction Process following the narrow loss to England. The playmaker was cited for remonstrating with referee Angus Gardner after the final whistle, with official reports also noting physical contact with the official. The misconduct charge follows a volatile finish in Santiago del Estero where a late Bautista Delguy try was overturned by the TMO. If suspended, the 28-year-old pivot faces a significant spell on the sidelines ahead of the remaining Nations Championship fixtures."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "461": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "SQUAD SELECTION",
          "heading": "Les Kiss recalls Lukhan Salakaia-Loto and names Isaac Henry in first Wallabies squad",
          "body": "Les Kiss has signalled a period of evolution by retaining Harry Wilson as captain in his first 34-man Wallabies squad. The selection includes Queensland Reds centre Isaac Henry as the only uncapped player, following a series-ending ankle injury for Len Ikitau. Powerhouse lock Lukhan Salakaia-Loto returns after what Kiss described as a \"robust conversation\" regarding his Test recall, while veteran James Slipper is rested. Racing 92 tighthead Taniela Tupou remains the sole overseas-based player in the group."
        }
      ],
      "source": {
        "name": "Guardian Rugby Union"
      }
    },
    "463": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "Travel concerns",
          "heading": "Ben Earl's travel criticism creates logistical uncertainty for Japan's upcoming campaign",
          "body": "The debate over the Nations Championship format remains at a standstill today as tournament organisers have yet to respond to concerns regarding \"brutal\" player travel. Reported on Wednesday, England’s Ben Earl led calls for schedule amendments to protect player welfare, a sentiment that directly impacts a Japan side currently 10 of 12 on the log. With no official updates surfacing in today's press, the Brave Blossoms' long-haul itinerary remains unchanged despite the mounting pressure for a more sustainable international calendar."
        }
      ],
      "source": {
        "name": "Guardian Rugby Union"
      },
      "rung": "storyline"
    },
    "465": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "Selection call",
          "heading": "Dave Rennie considers Siale Lauaki as bolter for South Africa tour",
          "body": "New Zealand remain unbeaten in three matches under Dave Rennie, but the squad for August’s eight-match tour of South Africa is now the focus. Hurricanes prop Siale Lauaki is tipped as a potential bolter to provide loosehead depth alongside Ollie Norris, as Tamaiti Williams remains unavailable. Rennie is expected to name a 44-man group on Monday, having already prioritised \"optimism\" during the Nations Championship. Selection for this \"Greatest Rivalry\" series is seen by Sean Fitzpatrick as vital preparation for next year’s World Cup."
        }
      ],
      "source": {
        "name": "SA Rugby Magazine"
      }
    },
    "467": {
      "date": "2026-07-24",
      "edition": "Friday 24 July",
      "sections": [
        {
          "kicker": "SQUAD SELECTION",
          "heading": "Rassie Erasmus recalls Siya Kolisi and Sacha Feinberg-Mngomezulu in 43-man Springboks squad",
          "body": "Head coach Rassie Erasmus has named a 43-man squad for upcoming Tests, headlined by 10 players returning from injury including Eben Etzebeth and Handré Pollard. He is splitting the group; one travels to face Argentina next month, while others stay behind to prepare for the All Blacks. Regarding the returnees, Erasmus noted that \"some players are returning from injury and need some valuable game time\" before the squad for the New Zealand series is finalised."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    }
  }
}