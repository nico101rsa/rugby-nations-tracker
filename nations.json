  "digests": {
    "28": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "Winless run",
          "heading": "Fiji suffer third consecutive loss following home defeat against Scotland",
          "body": "Fiji sit bottom of the Nations Championship table after suffering three consecutive defeats in the tournament. In their last five matches, the Flying Fijians have recorded one victory and four defeats. This current run of three straight losses includes their most recent fixture, a 33-17 home defeat against Scotland in July 2026. The team has scored 49 points in this campaign, while conceding 145 points."
        }
      ],
      "rung": "data"
    },
    "386": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "CONDUCT ROW",
          "heading": "Ben Youngs and Anthony Watson condemn Argentina's \"disgraceful\" conduct during England’s victory",
          "body": "The fallout from Saturday's 31-24 win has intensified as Ben Youngs and Anthony Watson called for World Rugby to punish Argentina for “disgraceful” conduct. Youngs condemned the behaviour of Los Pumas players who surrounded referee Angus Gardner, alongside Felipe Contepomi’s press conference walkout. With Watson highlighting allegations of racist abuse that were previously “brushed under the rug”, Youngs labelled the overall antics “unforgivable”. The pair are urging the governing body to issue bans following scuffles and a suspected punch on Tommy Freeman."
        }
      ],
      "match": {
        "referee": "Angus Gardner"
      },
      "source": {
        "name": "Planet Rugby"
      }
    },
    "387": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "SQUAD DEPTH",
          "heading": "Fabien Galthié's second-string France squad finishes July top of the northern standings",
          "body": "France concluded the Southern Hemisphere leg of the inaugural Nations Championship top of the Northern Hemisphere standings after a 42-15 victory against Japan. Fabien Galthié utilised 35 players across the three-match tour, notably resting stars such as Antoine Dupont and Thomas Ramos while Grégory Alldritt remained sidelined by injury. Despite losing the opener in Christchurch, Les Bleus secured their first win in Brisbane for 54 years against Australia. Galthié’s \"understudies\" now hold 12 log points, keeping them ahead of Scotland and England before November's home fixtures."
        }
      ],
      "match": {
        "venue": "Parc Olympique Lyonnais, Lyon"
      },
      "source": {
        "name": "Planet Rugby"
      }
    },
    "388": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "Verbal broadside",
          "heading": "Justin Marshall labels Ireland a \"pack of whingers\" after Eden Park defeat",
          "body": "Former All Blacks scrum-half Justin Marshall has criticised Ireland’s reaction to their 40-21 loss at Eden Park, labelling Andy Farrell’s side a \"pack of whingers.\" Speaking on the GBRANZ podcast, the New Zealander dismissed Irish frustrations regarding Luke Jacobson’s escaped red card and a missed yellow for centre Quinn Tupaea. He argued that the squad should \"sort out your own s*** first\" rather than blaming officials for an error-strewn display that saw Ireland drop the ball 15 times and miss crucial tackles during the third-round defeat."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "389": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "Touchline brawl",
          "heading": "Marco Riccioni handed two-match suspension for role in Australia touchline brawl",
          "body": "Italy tighthead Marco Riccioni has been handed a two-match suspension for \"conduct contrary to the spirit of good sportsmanship\" following Saturday’s touchline brawl in Perth. Riccioni received an unusual red card in the 66th minute for joining a trackside scuffle that spilled from the pitch during the 57-10 defeat. The Foul Play Review Committee reduced a four-week entry point following Riccioni’s admission of guilt and disciplinary history. While the Perpignan-bound prop will miss two club friendlies, the ban does not impact his availability for November’s test against South Africa."
        }
      ],
      "match": {
        "venue": "HBF Park, Perth"
      },
      "source": {
        "name": "Planet Rugby"
      }
    },
    "390": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "Top-tier ambition",
          "heading": "Pierre Schoeman claims Scotland are a top-three side after Fiji comeback",
          "body": "Prop Pierre Schoeman insists Scotland belong among the world's top three nations following their 33-17 bonus-point victory over Fiji. Despite trailing 17-7 at the interval, Gregor Townsend’s side utilised a powerful bench—including Scott Cummings and Jamie Dobie—to turn the tide at Murrayfield. The result leaves Scotland second in the northern table behind France at the end of the summer Tests. Schoeman dismissed suggestions that the gap is merely closing, arguing that Scotland have already proven they can go toe-to-toe with the world’s 'top dogs'."
        }
      ],
      "match": {
        "venue": "Murrayfield, Edinburgh"
      },
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "391": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "COACHING APPOINTMENT",
          "heading": "Leigh Halfpenny joins Cardiff as full-time coach after Wales coaching stint",
          "body": "The Wales legend has traded his playing boots for a whistle, joining Cardiff as a full-time kicking and skills coach. Halfpenny, who earned 101 caps and scored 801 points for his country, spent the opening three rounds of the Nations Championship as the national side’s kicking coach. He believes the recent experience within Steve Tandy’s coaching set-up will prove invaluable at the Arms Park. \"I am thrilled to join Cardiff on a full-time basis,\" said the 37-year-old, who will also work with the academy."
        }
      ],
      "source": {
        "name": "SA Rugby Magazine"
      }
    },
    "460": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "Coaching scrutiny",
          "heading": "Felipe Contepomi accuses England of disrespect following post-match press conference walkout",
          "body": "Head coach Felipe Contepomi walked out of his post-match press conference following last Saturday's 24-31 defeat to England, citing a lack of respect from the opposition. Contepomi had requested that English representatives lower the volume of music and celebrations within the adjacent changing room, a request that went unheeded. The tense atmosphere followed a chaotic finale in which Argentina were denied a potential match-tying try by the TMO, compounding a difficult afternoon in Santiago del Estero."
        }
      ],
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "461": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "Coaching scrutiny",
          "heading": "Joe Schmidt faces criticism as win-loss record falls below expectations",
          "body": "Following the Wallabies' recent 57-10 win over Italy, scrutiny has intensified regarding the tenure of Joe Schmidt. While the attacking breakdown and set-piece improvements were noted in the Perth victory, reports indicate his win-loss record stands at 38.71 per cent from 31 Tests. This performance marks the lowest winning percentage for an Australian coach in the professional era, keeping the side at No. 8 in the global rankings as the team prepares for further Nations Championship challenges."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "463": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "Individual honours",
          "heading": "Japanese bolter earns selection in Nations Championship Team of the Month",
          "body": "Following the conclusion of July's Nations Championship fixtures, a Japanese standout has been named in Planet Rugby’s Team of the Tournament. The selection recognises the best performers from the competition's opening three rounds, rewarding consistent quality across the month. While the squad features several heavy hitters from the tournament's unbeaten sides, the inclusion of a Japanese player highlights the impact made by the Brave Blossoms during this opening block of the new international competition."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "465": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "Media fallout",
          "heading": "Justin Marshall labels Ireland a pack of whingers following victory",
          "body": "Former All Black Justin Marshall has criticised Ireland for their reaction to officiating decisions during Saturday's 40-21 win at Eden Park. Speaking on the GBRANZ podcast, Marshall dismissed complaints regarding a yellow card for Luke Jacobson and a ruling on Quinn Tupaea, suggesting Ireland should focus on their own errors rather than blaming external factors. He noted that the visitors conceded costly turnovers and missed tackles, stating, “Sort out your own s*** first and don't blame everyone else.”"
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "467": {
      "date": "2026-07-23",
      "edition": "Thursday 23 July",
      "sections": [
        {
          "kicker": "Selection call",
          "heading": "Rassie Erasmus recalls 10 Springboks as he splits his 43-man squad",
          "body": "Rassie Erasmus has named 10 returning players, including Siya Kolisi, Sacha Feinberg-Mngomezulu, and Handré Pollard, in a 43-man squad for the upcoming Tests against Argentina and New Zealand. The head coach will split the group, with some remaining in Johannesburg to prepare for the All Blacks while others travel to Buenos Aires. “We decided that splitting the squad into two groups will be best for the Springbok team and the players to play their way into the squad,” Erasmus stated."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    }
  }
