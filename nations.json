  "digests": {
    "28": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Stats desk",
          "heading": "Fiji maintain high scoring average despite winless Nations Championship start",
          "body": "Fiji have averaged 28.6 points scored across their last 11 internationals. During this period, the side has conceded an average of 29.6 points per game. Total points scored reached 315, while 326 were conceded in return. While the current Nations Championship campaign remains without a victory following the 17-33 loss to Scotland, the window includes a 63-10 home win over Canada in September 2025. That Pacific Nations Cup knockout victory remains the largest winning margin for the Flying Fijians in recent years."
        }
      ],
      "rung": "data"
    },
    "386": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Schedule criticism",
          "heading": "Ben Earl slams \"brutal\" Nations Championship travel demands after 26,000-mile July tour",
          "body": "England No. 8 Ben Earl has called for a rethink of the Nations Championship format, describing the inaugural tournament’s travel schedule as “brutal.” Following Saturday’s 31-24 win in Argentina, Earl highlighted the physical toll of covering 26,000 miles across three continents in just three weeks. After fixtures in Johannesburg, Liverpool and Santiago del Estero, the Saracens forward suggested organisers should prioritise a \"festival feel\" by hosting clusters of matches in a single nation to reduce the logistical burden on players."
        }
      ],
      "source": {
        "name": "Guardian Rugby Union"
      }
    },
    "387": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "SELECTION DEPTH",
          "heading": "Fabien Galthié’s fringe players secure Nations Championship lead after dominant Japan win",
          "body": "The Southern Hemisphere leg concluded with a 42-15 victory over Japan, leaving France top of the Northern Hemisphere standings with 12 points. Fabien Galthié utilised 35 players across three Tests, securing significant away wins in Brisbane and Tokyo despite leaving star names like Antoine Dupont, Grégory Alldritt, and Thomas Ramos at home. Following a narrow opening-round loss to New Zealand in Christchurch, this rotated squad’s ability to claim three bonus points ensures Les Bleus lead the chasing pack of home nations."
        }
      ],
      "match": {
        "venue": "Parc Olympique Lyonnais, Lyon"
      },
      "source": {
        "name": "Planet Rugby"
      }
    },
    "388": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Citing controversy",
          "heading": "Owen Doyle slams officials after Luke Jacobson escapes citing for head contact",
          "body": "Former international referee Owen Doyle has criticised the \"shocker\" decision to allow New Zealand’s Luke Jacobson to escape further sanction following Saturday's 21-40 defeat. Doyle expressed disbelief that the flanker's tucked-shoulder clearout on Josh van der Flier was not upgraded to a red card by the bunker official. While Andy Farrell’s side now enters the off-season to re-assess an error-strewn Auckland performance, the failure of citing commissioners to act on the \"totally reckless\" challenge remains a major talking point."
        }
      ],
      "match": {
        "venue": "Eden Park, Auckland",
        "referee": "Nic Berry"
      },
      "source": {
        "name": "Planet Rugby"
      }
    },
    "389": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Statistical summary",
          "heading": "Italy sit 11th in the table after three Nations Championship defeats",
          "body": "Italy currently sit 11th in the 12-team Nations Championship table after three rounds of competition. The side remains without a victory, recording three losses. In their most recent fixture, the team suffered a 57-10 defeat to Australia. Historically, the Azzurri have reached a peak world ranking of No. 8, achieved in both 2007 and 2024. The squad have scored 37 points this campaign. They have conceded 131 points across those same three matches. Their current points difference stands at -94."
        }
      ],
      "rung": "data"
    },
    "390": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Statistical review",
          "heading": "Scotland maintain high scoring rate throughout recent run of international matches",
          "body": "Scotland have demonstrated a consistent attacking threat over their last 11 fixtures, scoring 348 points while conceding 299. This period averages 31.6 points scored and 27.2 points conceded per game. The most significant result during this recent window remains the 56-0 home victory against Tonga. Gregor Townsend’s side, currently fifth in the log, recently concluded their summer campaign with a 33-17 win over Fiji, aided by a productive second-half impact from the bench."
        }
      ],
      "rung": "data"
    },
    "391": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Growth assessment",
          "heading": "Jac Morgan insists Wales are closing the gap to world’s best",
          "body": "Despite enduring a chastening 43-0 defeat to South Africa, Jac Morgan maintains that Wales are making tangible progress. The flanker, who recently completed a move to Gloucester, pointed to the side's development since the autumn and their summer victory over Fiji as evidence of improvement. While head coach Steve Tandy remains \"bitterly disappointed\" by the recent scoreless showing in Durban, Morgan is optimistic that the squad's cohesion is increasing as they continue to build experience ahead of next year’s World Cup."
        }
      ],
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "460": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Coaching scrutiny",
          "heading": "Felipe Contepomi accuses England of disrespect following heated Nations Championship loss",
          "body": "Head coach Felipe Contepomi walked out of his post-match news conference after Saturday's defeat, citing a \"lack of respect\" from the England squad. Contepomi reported that the opposition's loud celebrations and music in the neighbouring dressing room caused tension following the chaotic 24-31 result. The match, which saw seven total yellow cards and a controversial TMO intervention in the final play, has also prompted calls from pundits for World Rugby to investigate further reports of player-official contact and crowd abuse."
        }
      ],
      "source": {
        "name": "BBC Rugby Union"
      }
    },
    "461": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Selection news",
          "heading": "Izaia Perese returns to Australian Rugby, signing with the Queensland Reds",
          "body": "Izaia Perese has confirmed his return to Australia, signing a two-season deal with the Queensland Reds following his exit from Leicester Tigers. The centre, who earned the last of his six Test caps during the 2023 World Cup, stated that playing for his country remains a primary objective. Rugby Australia’s director of high performance, Peter Horne, noted that the signing is intended to strengthen depth and ensure elite talent remains within the Australian system for the 2027 World Cup cycle."
        }
      ]
    },
    "463": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Tournament honours",
          "heading": "Japanese bolter earns selection in Nations Championship Team of the Month",
          "body": "Following the conclusion of the Nations Championship’s southern leg, a Japanese player has been named in Planet Rugby’s Team of the Tournament. The selection panel rewarded consistent performances over the three-round July block, acknowledging the newcomers’ impact alongside established tier-one giants. While Japan continues to navigate the competitive southern hemisphere standings, this individual recognition reflects the team’s growing influence, which has seen the Brave Blossoms combine a tournament-leading tackle success rate with an encouraging, if demanding, start to the campaign."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "465": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Selection call",
          "heading": "Sir John Kirwan backs Dave Rennie’s tactical shift for Springboks tour",
          "body": "All Blacks legend Sir John Kirwan has endorsed coach Dave Rennie’s recent selection experiments, noting a deliberate push for increased physical presence in the pack. By shifting Tupou Vaa’i to blindside flanker and introducing Patrick Tuipulotu at lock, the side has prioritised size to combat the Springboks' forward-dominated game plan. Kirwan believes the tactical adjustment is essential for the upcoming tour, stating: “If we're going to South Africa and want any chance to win, we've got to match them up front.”"
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    },
    "467": {
      "date": "2026-07-22",
      "edition": "Wednesday 22 July",
      "sections": [
        {
          "kicker": "Rivalry series",
          "heading": "Sir John Kirwan expects Dave Rennie to target Springboks' physical intensity",
          "body": "All Blacks legend Sir John Kirwan suggests that New Zealand coach Dave Rennie is already shaping his side with the upcoming series against South Africa in mind. Kirwan noted the strategic move to deploy a heavier pack, specifically citing the selection of lock Patrick Tuipulotu and Tupou Vaa'i in the back row to match the world champions. Kirwan warned that the All Blacks must be prepared to be \"brutal\" to stop the Springboks' momentum and physicality in their path."
        }
      ],
      "source": {
        "name": "Planet Rugby"
      }
    }
  }
